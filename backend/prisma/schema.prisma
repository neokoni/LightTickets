generator client {
  provider = "prisma-client-js"
}

enum Role {
  player
  staff
  admin
}

enum TicketStatus {
  open
  in_progress
  closed
  invalid
}

enum CommentSource {
  web
  minecraft
}

enum FederatedAuthProtocol {
  oidc
  oauth
}

enum FederatedAuthIntent {
  login
  link
}

enum FederatedAuthSecretMode {
  basic
  post
  bcrypt
}

model User {
  id                  Int                  @id @default(autoincrement())
  email               String               @unique
  passwordHash        String               @map("password_hash")
  username            String               @unique
  minecraftUuid       String?              @unique @map("minecraft_uuid")
  minecraftName       String?              @map("minecraft_name")
  avatarUrl           String?              @map("avatar_url")
  receiveEmailNotifications Boolean        @default(true) @map("receive_email_notifications")
  role                Role                 @default(player)
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  authoredTickets     Ticket[]             @relation("TicketAuthor")
  assignedTickets     Ticket[]             @relation("TicketAssignee")
  ticketAssignments   TicketAssignee[]
  comments            Comment[]
  attachments         Attachment[]
  auditLogs           AuditLog[]
  passwordResetTokens PasswordResetToken[]
  federatedAuthIdentities FederatedAuthIdentity[]
  federatedAuthFlows FederatedAuthFlow[]

  @@map("users")
}

model FederatedAuthProvider {
  id                    String                  @id @default(uuid())
  slug                  String                  @unique
  name                  String
  iconUrl               String?                 @map("icon_url")
  protocol              FederatedAuthProtocol
  issuer                String?
  authorizationEndpoint String?                 @map("authorization_endpoint")
  tokenEndpoint         String?                 @map("token_endpoint")
  userInfoEndpoint      String?                 @map("user_info_endpoint")
  redirectUri           String                  @map("redirect_uri")
  clientId              String                  @map("client_id")
  clientSecretEncrypted String?                 @map("client_secret_encrypted")
  scope                 String
  subjectPath           String                  @map("subject_path")
  usernamePath          String?                 @map("username_path")
  emailPath             String?                 @map("email_path")
  avatarPath            String?                 @map("avatar_path")
  authorizationParams   String?                 @map("authorization_params")
  pkce                  Boolean                 @default(true)
  secretMode            FederatedAuthSecretMode @default(basic) @map("secret_mode")
  accessTokenPath       String                  @default("access_token") @map("access_token_path")
  enabled               Boolean                 @default(false)
  allowRegistration     Boolean                 @default(false) @map("allow_registration")
  createdAt             DateTime                @default(now()) @map("created_at")
  updatedAt             DateTime                @updatedAt @map("updated_at")
  identities            FederatedAuthIdentity[]
  flows                 FederatedAuthFlow[]
  registrations         FederatedAuthRegistration[]

  @@map("federated_auth_providers")
}

model FederatedAuthIdentity {
  id           String                @id @default(uuid())
  userId       Int                   @map("user_id")
  providerId   String                @map("provider_id")
  subject      String
  usernameHint String?               @map("username_hint")
  emailHint    String?               @map("email_hint")
  avatarUrl    String?               @map("avatar_url")
  lastLoginAt  DateTime?             @map("last_login_at")
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")
  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  provider     FederatedAuthProvider @relation(fields: [providerId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([providerId, subject])
  @@unique([userId, providerId])
  @@index([userId])
  @@map("federated_auth_identities")
}

model FederatedAuthFlow {
  id                 String                @id @default(uuid())
  stateHash          String                @unique @map("state_hash")
  browserHash        String                @map("browser_hash")
  providerId         String                @map("provider_id")
  intent             FederatedAuthIntent
  userId             Int?                  @map("user_id")
  returnTo           String                @map("return_to")
  payloadEncrypted   String                @map("payload_encrypted")
  expiresAt          DateTime              @map("expires_at")
  usedAt             DateTime?             @map("used_at")
  createdAt          DateTime              @default(now()) @map("created_at")
  provider           FederatedAuthProvider @relation(fields: [providerId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  user               User?                 @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([expiresAt])
  @@index([userId])
  @@map("federated_auth_flows")
}

model FederatedAuthRegistration {
  id           String                @id @default(uuid())
  tokenHash    String                @unique @map("token_hash")
  providerId   String                @map("provider_id")
  subject      String
  usernameHint String?               @map("username_hint")
  emailHint    String?               @map("email_hint")
  avatarUrl    String?               @map("avatar_url")
  expiresAt    DateTime              @map("expires_at")
  usedAt       DateTime?             @map("used_at")
  createdAt    DateTime              @default(now()) @map("created_at")
  provider     FederatedAuthProvider @relation(fields: [providerId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([providerId, subject])
  @@index([expiresAt])
  @@map("federated_auth_registrations")
}

model Server {
  id          String     @id @default(uuid())
  name        String     @unique
  apiKey      String     @unique @map("api_key")
  address     String?
  description String?
  createdAt   DateTime   @default(now()) @map("created_at")
  tickets     Ticket[]
  linkCodes   LinkCode[]

  @@map("servers")
}

model Ticket {
  id          Int              @id @default(autoincrement())
  title       String
  body        String
  template    String           @default("")
  formData    String?          @map("form_data")
  gameContext String?          @map("game_context")
  status      TicketStatus     @default(open)
  hidden      Boolean          @default(false)
  authorId    Int              @map("author_id")
  serverId    String?          @map("server_id")
  assigneeId  Int?             @map("assignee_id")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  closedAt    DateTime?        @map("closed_at")
  author      User             @relation("TicketAuthor", fields: [authorId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  server      Server?          @relation(fields: [serverId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  assignee    User?            @relation("TicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  labels      TicketLabel[]
  assignees   TicketAssignee[]
  comments    Comment[]
  attachments Attachment[]
  auditLogs   AuditLog[]

  @@map("tickets")
}

model Label {
  id          String        @id @default(uuid())
  name        String        @unique
  color       String
  description String?
  tickets     TicketLabel[]

  @@map("labels")
}

model TicketLabel {
  ticketId Int    @map("ticket_id")
  labelId  String @map("label_id")
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  label    Label  @relation(fields: [labelId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@id([ticketId, labelId])
  @@map("ticket_labels")
}

model TicketAssignee {
  ticketId Int    @map("ticket_id")
  userId   Int    @map("user_id")
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@id([ticketId, userId])
  @@map("ticket_assignees")
}

model Comment {
  id          String        @id @default(uuid())
  ticketId    Int           @map("ticket_id")
  authorId    Int           @map("author_id")
  body        String
  source      CommentSource @default(web)
  createdAt   DateTime      @default(now()) @map("created_at")
  ticket      Ticket        @relation(fields: [ticketId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  author      User          @relation(fields: [authorId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  attachments Attachment[]

  @@map("comments")
}

model Attachment {
  id          String   @id @default(uuid())
  ticketId    Int?     @map("ticket_id")
  commentId   String?  @map("comment_id")
  filename    String
  path        String
  mimeType    String   @map("mime_type")
  size        Int
  storageType String   @default("local") @map("storage_type")
  uploadedBy  Int      @map("uploaded_by")
  createdAt   DateTime @default(now()) @map("created_at")
  ticket      Ticket?  @relation(fields: [ticketId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  comment     Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  uploader    User     @relation(fields: [uploadedBy], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@map("attachments")
}

model LinkCode {
  id            String   @id @default(uuid())
  code          String   @unique
  minecraftUuid String   @map("minecraft_uuid")
  minecraftName String   @map("minecraft_name")
  serverId      String   @map("server_id")
  expiresAt     DateTime @map("expires_at")
  used          Boolean  @default(false)
  server        Server   @relation(fields: [serverId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@map("link_codes")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    Int       @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model RegistrationEmailVerification {
  email     String   @id
  codeHash  String   @map("code_hash")
  expiresAt DateTime @map("expires_at")
  attempts  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([expiresAt])
  @@map("registration_email_verifications")
}

model SetupStatus {
  id               String   @id @default(uuid())
  isSetup          Boolean  @default(false) @map("is_setup")
  siteName         String   @default("LightTickets") @map("site_name")
  siteUrl          String?  @map("site_url")
  requireLogin     Boolean  @default(false) @map("require_login")
  allowWebRegister Boolean  @default(true) @map("allow_web_register")
  allowMcRegister  Boolean  @default(true) @map("allow_mc_register")
  sendEmailNotifications Boolean @default(false) @map("send_email_notifications")
  footerContent    String?  @map("footer_content")
  defaultLanguage  String   @default("zh-CN") @map("default_language")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("setup_status")
}

model AppConfig {
  id              String   @id @default(uuid())
  storageDriver   String   @default("local") @map("storage_driver")
  uploadDir       String   @default("data/uploads") @map("upload_dir")
  s3Config        String?  @map("s3_config")
  mailConfig      String?  @map("mail_config")
  turnstileConfig String?  @map("turnstile_config")
  rateLimitConfig String?  @map("rate_limit_config")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("app_config")
}

model AuditLog {
  id        String   @id @default(uuid())
  ticketId  Int      @map("ticket_id")
  actorId   Int      @map("actor_id")
  action    String
  oldValue  String?  @map("old_value")
  newValue  String?  @map("new_value")
  createdAt DateTime @default(now()) @map("created_at")
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  actor     User     @relation(fields: [actorId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@map("audit_logs")
}
